generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum JornadaEstado {
  abierta
  cerrada
}

enum OrigenLineaVenta {
  partida
  piso
}

enum TipoDevolucion {
  pelado
  muerto
  vivo
}

enum TipoCliente {
  mayorista
  minorista
}

enum EstadoFactura {
  pendiente
  pago_parcial
  pagado
  anulado
}

enum TipoPago {
  efectivo
  deposito
}

enum EstadoPago {
  pendiente
  confirmado
  rechazado
}

enum UserRole {
  operario
  admin
  cajero
  oficina
}

enum GuiaEstado {
  borrador
  cerrada
  anulada
}

model Usuario {
  id              Int       @id @default(autoincrement())
  username        String    @unique
  password_hash   String
  nombre          String?
  email           String?
  role            UserRole
  activo          Boolean   @default(true)
  created_by      Int?
  updated_by      Int?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
  creator         Usuario?  @relation("UsuarioCreatedBy", fields: [created_by], references: [id], onDelete: SetNull)
  updater         Usuario?  @relation("UsuarioUpdatedBy", fields: [updated_by], references: [id], onDelete: SetNull)
  created_users   Usuario[] @relation("UsuarioCreatedBy")
  updated_users   Usuario[] @relation("UsuarioUpdatedBy")
  deleted_lineas_venta LineaVenta[] @relation("LineaVentaDeletedBy")
  facturas_creadas Factura[] @relation("FacturaCreatedBy")
  pagos_registrados Pago[] @relation("PagoRegistradoPor")
  pagos_validados Pago[] @relation("PagoValidadoPor")
  egresos_registrados Egreso[] @relation("EgresoRegistradoPor")
  precios_creados     Precio[] @relation("PrecioCreadoPor")
  guias_creadas       GuiaEntrega[]  @relation("GuiaCreadaPor")
  guias_cerradas      GuiaEntrega[]  @relation("GuiaCerradaPor")

  @@map("usuario")
}

model Jornada {
  id             Int            @id @default(autoincrement())
  fecha          DateTime       @default(now())
  codigo         String         @unique
  estado         JornadaEstado  @default(abierta)
  desperdicio_kg Decimal?       @db.Decimal(10, 2)
  muertero_kg    Decimal?       @db.Decimal(10, 2)
  created_at     DateTime       @default(now())
  entradas       EntradaGranja[]
  lineas_venta   LineaVenta[]
  devoluciones   Devolucion[]
  sobrantes      Sobrante[]     @relation("SobrantesActuales")
  sobrantes_de   Sobrante[]     @relation("SobrantesOrigen")
  facturas       Factura[]
  guias          GuiaEntrega[]

  @@map("jornada")
}

model Granja {
  id         Int            @id @default(autoincrement())
  nombre     String         @unique
  activo     Boolean        @default(true)
  created_at DateTime       @default(now())
  entradas   EntradaGranja[]
  ventas     LineaVenta[]

  @@map("granja")
}

model Cliente {
  id           Int          @id @default(autoincrement())
  nombre       String       @unique
  codigo       String?      @unique
  tipo         TipoCliente  @default(minorista)
  documento_tipo String?
  documento_num  String?
  contacto     String?
  telefono     String?
  email        String?
  direccion    String?
  activo       Boolean      @default(true)
  created_at   DateTime     @default(now())
  lineas_venta LineaVenta[]
  devoluciones Devolucion[]
  facturas     Factura[]
  pagos        Pago[]
  guias        GuiaEntrega[]

  @@index([activo])
  @@index([tipo, activo])
  @@map("cliente")
}

model EntradaGranja {
  id                  Int      @id @default(autoincrement())
  jornada_id          Int
  granja_id           Int
  jabas_total         Int
  peso_bruto          Decimal  @db.Decimal(10, 2)
  tara                Decimal  @db.Decimal(10, 2)
  peso_neto           Decimal  @db.Decimal(10, 2)
  peso_salida_granja  Decimal? @db.Decimal(10, 2)
  peso_ingreso_local  Decimal? @db.Decimal(10, 2)
  combustible_kg      Decimal  @default(0) @db.Decimal(10, 2)
  created_at          DateTime @default(now())
  jornada             Jornada  @relation(fields: [jornada_id], references: [id], onDelete: Cascade)
  granja              Granja   @relation(fields: [granja_id], references: [id])

  @@map("entrada_granja")
}

model LineaVenta {
  id             Int              @id @default(autoincrement())
  jornada_id     Int
  cliente_id     Int?
  granja_id      Int
  origen         OrigenLineaVenta
  jabas          Int
  peso_bruto     Decimal          @db.Decimal(10, 2)
  tara           Decimal          @db.Decimal(10, 2)
  tara_por_jaba  Decimal          @default(5.8) @db.Decimal(10, 2)
  peso_neto      Decimal          @db.Decimal(10, 2)
  nota           String?
  deleted_at     DateTime?
  deleted_by     Int?
  delete_reason  String?
  created_at     DateTime         @default(now())
  jornada        Jornada          @relation(fields: [jornada_id], references: [id], onDelete: Cascade)
  cliente        Cliente?         @relation(fields: [cliente_id], references: [id])
  granja         Granja           @relation(fields: [granja_id], references: [id])
  deleter        Usuario?         @relation("LineaVentaDeletedBy", fields: [deleted_by], references: [id], onDelete: SetNull)
  linea_guia     LineaGuia?
  devoluciones   Devolucion[]

  @@index([deleted_at])
  @@map("linea_venta")
}

model Producto {
  id         Int            @id @default(autoincrement())
  codigo     String         @unique
  nombre     String
  activo     Boolean        @default(true)
  created_at DateTime       @default(now())
  updated_at DateTime       @updatedAt
  precios    Precio[]
  guias      GuiaEntrega[]

  @@map("producto")
}

model Precio {
  id          String    @id @default(uuid())
  producto_id Int
  precio      Decimal   @db.Decimal(10, 4)
  fecha_desde DateTime  @db.Date
  fecha_hasta DateTime? @db.Date
  vigente     Boolean   @default(false)
  creado_por  Int
  creado_en   DateTime  @default(now()) @map("creado_en")
  producto    Producto  @relation(fields: [producto_id], references: [id])
  creador     Usuario   @relation("PrecioCreadoPor", fields: [creado_por], references: [id])
  lineas_guia LineaGuia[]

  @@index([producto_id, fecha_desde])
  @@index([producto_id, vigente])
  @@map("precios")
}

model GuiaEntrega {
  id                 Int         @id @default(autoincrement())
  numero             String      @unique
  jornada_id         Int
  cliente_id         Int
  producto_id        Int
  fecha_emision      DateTime    @default(now()) @db.Date
  estado             GuiaEstado  @default(borrador)
  saldo_anterior     Decimal     @default(0) @db.Decimal(12, 2)
  total_peso_neto    Decimal     @default(0) @db.Decimal(10, 2)
  total_devolucion   Decimal     @default(0) @db.Decimal(10, 2)
  total_neto         Decimal     @default(0) @db.Decimal(10, 2)
  total_importe      Decimal     @default(0) @db.Decimal(12, 2)
  total_peladuria    Decimal     @default(0) @db.Decimal(12, 2)
  total_general      Decimal     @default(0) @db.Decimal(12, 2)
  precio_kg_aplicado Decimal?    @db.Decimal(10, 4)
  observaciones      String?
  creado_por         Int
  cerrada_por        Int?
  cerrada_at         DateTime?
  created_at         DateTime    @default(now())
  updated_at         DateTime    @updatedAt
  jornada            Jornada     @relation(fields: [jornada_id], references: [id], onDelete: Restrict)
  cliente            Cliente     @relation(fields: [cliente_id], references: [id])
  producto           Producto    @relation(fields: [producto_id], references: [id])
  operador           Usuario     @relation("GuiaCreadaPor", fields: [creado_por], references: [id])
  cerrador           Usuario?    @relation("GuiaCerradaPor", fields: [cerrada_por], references: [id], onDelete: SetNull)
  lineas             LineaGuia[]
  pagos              Pago[]

  @@index([jornada_id, cliente_id])
  @@index([cliente_id, fecha_emision])
  @@index([estado])
  @@map("guia_entrega")
}

model LineaGuia {
  id               Int           @id @default(autoincrement())
  guia_id          Int
  orden            Int           @default(1)
  jabas            Int
  peso_bruto       Decimal       @db.Decimal(10, 2)
  tara_por_jaba    Decimal       @default(5.8) @db.Decimal(10, 2)
  tara             Decimal       @db.Decimal(10, 2)
  devolucion_kg    Decimal       @default(0) @db.Decimal(10, 2)
  peso_neto        Decimal       @db.Decimal(10, 2)
  neto_total       Decimal       @db.Decimal(10, 2)
  precio_kg        Decimal       @db.Decimal(10, 4)
  precio_id        String?
  importe_guia     Decimal       @default(0) @db.Decimal(12, 2)
  peladuria        Decimal       @default(0) @db.Decimal(12, 2)
  importe_total    Decimal       @default(0) @db.Decimal(12, 2)
  linea_venta_id   Int?          @unique
  nota             String?
  created_at       DateTime      @default(now())
  updated_at       DateTime      @updatedAt
  guia             GuiaEntrega   @relation(fields: [guia_id], references: [id], onDelete: Cascade)
  precio           Precio?       @relation(fields: [precio_id], references: [id], onDelete: SetNull)
  linea_venta      LineaVenta?   @relation(fields: [linea_venta_id], references: [id], onDelete: SetNull)

  @@index([guia_id, orden])
  @@map("linea_guia")
}

model Devolucion {
  id             Int            @id @default(autoincrement())
  jornada_id     Int
  cliente_id     Int
  linea_venta_id Int?
  tipo           TipoDevolucion
  jabas          Int?
  peso_bruto     Decimal        @db.Decimal(10, 2)
  tara           Decimal        @db.Decimal(10, 2)
  peso_neto      Decimal        @db.Decimal(10, 2)
  created_at     DateTime       @default(now())
  jornada        Jornada        @relation(fields: [jornada_id], references: [id], onDelete: Cascade)
  cliente        Cliente        @relation(fields: [cliente_id], references: [id])
  linea_venta    LineaVenta?    @relation(fields: [linea_venta_id], references: [id], onDelete: SetNull)

  @@index([linea_venta_id])
  @@map("devolucion")
}

model Sobrante {
  id                Int      @id @default(autoincrement())
  jornada_id        Int
  jornada_origen_id Int
  jabas             Int
  peso_bruto        Decimal  @db.Decimal(10, 2)
  tara              Decimal  @db.Decimal(10, 2)
  peso_neto         Decimal  @db.Decimal(10, 2)
  created_at        DateTime @default(now())
  jornada           Jornada  @relation("SobrantesActuales", fields: [jornada_id], references: [id], onDelete: Cascade)
  jornada_origen    Jornada  @relation("SobrantesOrigen", fields: [jornada_origen_id], references: [id])

  @@map("sobrante")
}

model Factura {
  id              Int           @id @default(autoincrement())
  codigo          String        @unique
  jornada_id      Int
  cliente_id      Int
  fecha_emision   DateTime      @default(now())
  monto_total     Decimal       @db.Decimal(10, 2)
  monto_pagado    Decimal       @default(0) @db.Decimal(10, 2)
  saldo_pendiente Decimal       @db.Decimal(10, 2)
  estado          EstadoFactura @default(pendiente)
  created_by      Int?
  created_at      DateTime      @default(now())
  updated_at      DateTime      @updatedAt
  jornada         Jornada       @relation(fields: [jornada_id], references: [id], onDelete: Cascade)
  cliente         Cliente       @relation(fields: [cliente_id], references: [id])
  creator         Usuario?      @relation("FacturaCreatedBy", fields: [created_by], references: [id], onDelete: SetNull)
  pagos           Pago[]

  @@index([jornada_id])
  @@index([cliente_id])
  @@index([estado])
  @@map("factura")
}

model Pago {
  id               Int        @id @default(autoincrement())
  factura_id       Int?
  guia_id          Int?
  cliente_id       Int
  monto            Decimal    @db.Decimal(10, 2)
  tipo             TipoPago
  metodo           String
  banco            String?
  nro_operacion    String?
  fecha_deposito   DateTime?  @db.Date
  hora_deposito    DateTime?  @db.Time(0)
  estado           EstadoPago @default(confirmado)
  validado_por     Int?
  fecha_validacion DateTime?
  observaciones    String?
  registrado_por   Int
  created_at       DateTime   @default(now())
  updated_at       DateTime   @updatedAt
  factura          Factura?   @relation(fields: [factura_id], references: [id])
  guia             GuiaEntrega? @relation(fields: [guia_id], references: [id])
  cliente          Cliente    @relation(fields: [cliente_id], references: [id])
  cajero           Usuario    @relation("PagoRegistradoPor", fields: [registrado_por], references: [id])
  validador        Usuario?   @relation("PagoValidadoPor", fields: [validado_por], references: [id], onDelete: SetNull)

  @@index([factura_id])
  @@index([guia_id])
  @@index([cliente_id])
  @@index([estado])
  @@index([registrado_por])
  @@map("pago")
}

model Egreso {
  id              Int      @id @default(autoincrement())
  concepto        String
  descripcion     String
  monto           Decimal  @db.Decimal(10, 2)
  metodo_pago     String
  beneficiario    String
  comprobante     String?
  fecha           DateTime @default(now())
  registrado_por  Int
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
  cajero          Usuario  @relation("EgresoRegistradoPor", fields: [registrado_por], references: [id])

  @@index([fecha])
  @@index([registrado_por])
  @@map("egreso")
}
